# --- Base de données TeslaMate ---
# DSN PostgreSQL de la base TeslaMate. Pointer vers le service `database` du
# compose TeslaMate, ou vers l'host/port exposé en local.
DATABASE_URL=postgresql://teslamate:CHANGE_ME@localhost:5432/teslamate?schema=public

# --- Authentification ---
# Login unique de l'application. Le mot de passe est stocké en hash bcrypt.
AUTH_USERNAME=admin
# Pour générer : `npm run auth:hash` (ou `node -e "..."`)
# IMPORTANT : échapper chaque `$` du hash avec `\$` ! `@next/env` (dotenv-expand)
# interprète `$2b`, `$12`, etc. comme des variables shell — y compris quand le
# hash est entre single-quotes. Le seul échappement qui fonctionne est `\$`.
# Exemple : AUTH_PASSWORD_HASH=\$2b\$12\$abcdef...
AUTH_PASSWORD_HASH=
# Clé de chiffrement des cookies de session (32 octets minimum).
# Pour générer : `openssl rand -base64 32`
AUTH_SECRET=

# --- Optionnel ---
DEFAULT_LOCALE=fr
LOG_LEVEL=info
READ_ONLY=false
PORT=3001

# --- Fleet API : photo officielle du véhicule (v0.5.2, optionnel) ---
# Affiche la photo officielle Tesla (compositor) dans le bloc STATUS de l'accueil.
# Source des codes option, par priorité : cache (payload API mémorisé) → Fleet API
# → repli `TESLA_VEHICLE_OPTIONS` ci-dessous. Aucun code n'est codé en dur : si ni
# l'API ni cette variable ne fournissent de codes, AUCUNE image n'est affichée.
#
# Clé de déchiffrement des tokens TeslaMate. DOIT être EXACTEMENT l'ENCRYPTION_KEY
# de l'instance TeslaMate qui a chiffré les tokens (sinon le déchiffrement échoue
# → repli sur TESLA_VEHICLE_OPTIONS). Lecture SEULE de la table `private.tokens`
# (TeslaMate récent) ou `public.tokens` (ancien). Laisser vide pour désactiver Fleet.
TESLAMATE_ENCRYPTION_KEY=
# Base régionale de la Fleet API (EU par défaut ; NA = ...prd.na.vn.cloud.tesla.com).
TESLA_FLEET_API_BASE_URL=https://fleet-api.prd.eu.vn.cloud.tesla.com
# Repli quand l'API Fleet est inaccessible (pas de token / clé KO / hors-ligne) :
# codes option EXACTS de ta voiture (séparés par des virgules), p.ex. copiés depuis
# l'URL compositor sur tesla.com. IMPORTANT : échapper chaque `$` en `\$` — `@next/env`
# (dotenv-expand) interprète `$xxx` comme une variable (même piège que le hash bcrypt).
# Laisser vide = pas d'image tant que l'API n'a pas répondu.
# Exemple : TESLA_VEHICLE_OPTIONS=\$MTY68,\$PPSW,\$WY18P,\$IBB6
TESLA_VEHICLE_OPTIONS=
